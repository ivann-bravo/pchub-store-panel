# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# database — ignore all files inside data/ except demo-seed.db
/data/*
!/data/demo-seed.db

# drizzle
/drizzle/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Data files (CSV de muestra, databases locales)
*.csv
local.db
*.db
!data/demo-seed.db
nul

# References (screenshots de trabajo)
/references/

# Claude Code local config
/.claude/

# Agent skills (se reinstalan localmente)
/.agents/

# Tasks (local workflow tracking)
/tasks/
