# Copy this to .env.local and fill in your values
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Demo mode — set both to "true" to enable demo/portfolio mode
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Leave these empty in demo mode — they are blocked by DEMO_MODE guards
# WOO_URL=
# WOO_CONSUMER_KEY=
# WOO_CONSUMER_SECRET=
# WOO_SYNC_SECRET=
# GEMINI_API_KEY=
# CRON_SECRET=
